      "item": [
        {
          "name": "Get Boards number / Ids/ Names",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "\r",
                  "console.clear();\r",
                  "\r",
                  "pm.test(\"Status code 200\", function() \r",
                  "{\r",
                  "    pm.response.to.have.status(200);\r",
                  "})\r",
                  "\r",
                  "if (response.length>0)\r",
                  "{\r",
                  "    pm.test(\"New Board is found\", function()\r",
                  "{\r",
                  "const newBoardFound = response.find(item => item.id === pm.collectionVariables.get(\"lastBoardId\"));\r",
                  "console.log(newBoardFound);\r",
                  "pm.expect(newBoardFound).to.be.an(\"object\");\r",
                  "});\r",
                  "};\r",
                  "const totalBoards = response.length;\r",
                  "console.log(\"Numarul de board-uri total este: \" + totalBoards);\r",
                  "\r",
                  "const boardsIds = [];\r",
                  "const boardsNames = [];\r",
                  "for (i=0; i<response.length; i++)\r",
                  "{\r",
                  "    boardsIds.push(response[i].id);\r",
                  "    boardsNames.push(response[i].name);\r",
                  "}\r",
                  "console.log(\"Lista cu Id-urile board-urilor: \" + boardsIds);\r",
                  "console.log(\"Lista cu numele board-urilor: \" + boardsNames);\r",
                  "\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
